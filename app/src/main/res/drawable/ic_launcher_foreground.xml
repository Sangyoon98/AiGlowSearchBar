<?xml version="1.0" encoding="utf-8"?>
<!-- The AiGlow mark: a sweep-gradient ring (soft halo + crisp ring), mirroring what
     the library draws. Fits the adaptive-icon 66dp safe zone (max extent r≈28 < 33).
     Also referenced as the monochrome (themed icon) layer — the ring reads well as an
     alpha mask. (한국어) 라이브러리가 그리는 것과 동일한 sweep 그라디언트 링(halo + 링).
     adaptive icon 안전 영역 안에 들어가며 모노크롬(테마 아이콘) 레이어로도 재사용됩니다. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft halo: same ring, wider and translucent. (한국어) 넓고 반투명한 halo. -->
    <path
        android:pathData="M54,54m-22,0a22,22 0 1,1 44,0a22,22 0 1,1 -44,0"
        android:fillColor="#00000000"
        android:strokeWidth="11"
        android:strokeAlpha="0.35">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="54"
                android:centerY="54">
                <item android:offset="0" android:color="#FF4285F4" />
                <item android:offset="0.33" android:color="#FF9B72CB" />
                <item android:offset="0.66" android:color="#FFD96570" />
                <item android:offset="1" android:color="#FF4285F4" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Crisp gradient ring. (한국어) 선명한 그라디언트 링. -->
    <path
        android:pathData="M54,54m-22,0a22,22 0 1,1 44,0a22,22 0 1,1 -44,0"
        android:fillColor="#00000000"
        android:strokeWidth="4.5">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="sweep"
                android:centerX="54"
                android:centerY="54">
                <item android:offset="0" android:color="#FF4285F4" />
                <item android:offset="0.33" android:color="#FF9B72CB" />
                <item android:offset="0.66" android:color="#FFD96570" />
                <item android:offset="1" android:color="#FF4285F4" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
